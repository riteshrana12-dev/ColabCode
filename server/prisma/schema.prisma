
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String  @id       @default(uuid())
  name       String
  email      String  @unique
  password   String
  verified   Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

 
}

